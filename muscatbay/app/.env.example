# Supabase Configuration
# Copy this file to .env.local and fill in your actual values
# Find your values at: https://supabase.com/dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL (set to your production domain for auth redirects)
# If not set, falls back to window.location.origin
# NEXT_PUBLIC_SITE_URL=https://your-app-domain.com

# Development Mode (ONLY for local development - NEVER enable in production)
# This bypasses authentication for testing purposes
# NEXT_PUBLIC_DEV_MODE=true
