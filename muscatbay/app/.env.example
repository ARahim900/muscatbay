# Supabase Configuration
# Copy this file to .env.local and fill in your actual values
# Find your values at: https://supabase.com/dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Development Mode (ONLY for local development - NEVER enable in production)
# This bypasses authentication for testing purposes
# NEXT_PUBLIC_DEV_MODE=true

# Grafana – Daily Water Report
# Option A: Service-account API key (preferred)
GRAFANA_API_KEY=your-grafana-service-account-token
# Option B: Basic auth (use EITHER Option A or B, not both)
# GRAFANA_USERNAME=admin
# GRAFANA_PASSWORD=your-grafana-password
